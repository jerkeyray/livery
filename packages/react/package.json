{
  "name": "@liveryscript/react",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "React renderer for token-efficient Livery diagrams and visual stories.",
  "license": "MIT",
  "author": "Aditya Srivastava",
  "repository": { "type": "git", "url": "git+https://github.com/jerkeyray/livery.git", "directory": "packages/react" },
  "homepage": "https://github.com/jerkeyray/livery#readme",
  "bugs": { "url": "https://github.com/jerkeyray/livery/issues" },
  "keywords": ["react", "agents", "diagrams", "visualization"],
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@liveryscript/core": "0.1.0-alpha.0",
    "@liveryscript/web": "0.1.0-alpha.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
