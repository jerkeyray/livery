{
  "name": "@liveryscript/web",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Framework-independent browser renderer and runtime for Livery visuals.",
  "license": "MIT",
  "author": "Aditya Srivastava",
  "repository": { "type": "git", "url": "git+https://github.com/jerkeyray/livery.git", "directory": "packages/web" },
  "homepage": "https://github.com/jerkeyray/livery#readme",
  "bugs": { "url": "https://github.com/jerkeyray/livery/issues" },
  "keywords": ["agents", "diagrams", "visualization", "browser"],
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./motion": {
      "types": "./dist/motion.d.mts",
      "import": "./dist/motion.mjs"
    },
    "./layout-controller": {
      "types": "./dist/layout-controller.d.mts",
      "import": "./dist/layout-controller.mjs"
    },
    "./controller": {
      "types": "./dist/controller.d.mts",
      "import": "./dist/controller.mjs"
    },
    "./visual-renderer": {
      "types": "./dist/visual-renderer.d.mts",
      "import": "./dist/visual-renderer.mjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@liveryscript/core": "0.1.0-alpha.0"
  }
}
