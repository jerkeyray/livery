{
  "name": "@livery/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./motion": {
      "types": "./dist/motion.d.mts",
      "import": "./dist/motion.mjs"
    },
    "./layout-controller": {
      "types": "./dist/layout-controller.d.mts",
      "import": "./dist/layout-controller.mjs"
    },
    "./controller": {
      "types": "./dist/controller.d.mts",
      "import": "./dist/controller.mjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@livery/core": "workspace:*"
  }
}
