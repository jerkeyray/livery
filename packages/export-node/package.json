{
  "name": "@jerkeyray/export-node",
  "version": "0.1.0",
  "description": "Optional Node and Bun PNG export adapter for Livery visuals.",
  "license": "MIT",
  "author": "Aditya Srivastava",
  "repository": { "type": "git", "url": "git+https://github.com/jerkeyray/livery.git", "directory": "packages/export-node" },
  "homepage": "https://github.com/jerkeyray/livery#readme",
  "bugs": { "url": "https://github.com/jerkeyray/livery/issues" },
  "keywords": ["png", "svg", "diagrams", "resvg"],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@jerkeyray/core": "workspace:*",
    "@resvg/resvg-js": "2.6.2"
  }
}
