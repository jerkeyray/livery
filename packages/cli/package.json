{
  "name": "@liveryscript/cli",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Command-line renderer for Livery DSL files, SVG, JSON, and PNG.",
  "license": "MIT",
  "author": "Aditya Srivastava",
  "repository": { "type": "git", "url": "git+https://github.com/jerkeyray/livery.git", "directory": "packages/cli" },
  "homepage": "https://github.com/jerkeyray/livery#readme",
  "bugs": { "url": "https://github.com/jerkeyray/livery/issues" },
  "keywords": ["cli", "agents", "diagrams", "svg", "png"],
  "type": "module",
  "bin": {
    "livery": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@liveryscript/core": "0.1.0-alpha.0",
    "@liveryscript/export-node": "0.1.0-alpha.0"
  }
}
