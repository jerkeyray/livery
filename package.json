{
  "name": "livery",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "bun run --filter '@liveryscript/*' build && bun run --filter liveryscript build",
    "dev": "bun run --filter @liveryscript/playground dev",
    "test": "vitest run",
    "test:visual": "playwright test",
    "test:packages": "bun run build && bun scripts/smoke-packages.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json && bun run --filter '@liveryscript/*' typecheck && bun run --filter liveryscript typecheck",
    "bench:agent": "tsx scripts/benchmark-agent.ts",
    "bench:tokens": "tsx scripts/benchmark-tokens.ts",
    "eval:agent": "tsx scripts/evaluate-agents.ts",
    "docs:check": "bun scripts/generate-docs-reference.ts && bun scripts/check-docs.ts",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:packages": "changeset publish --tag alpha",
    "changeset:status": "changeset status",
    "lint:packages": "publint packages/liveryscript && attw --profile esm-only --exclude-entrypoints ./styles.css --pack packages/liveryscript",
    "verify:release": "bun run changeset:status && bun run typecheck && bun run test && bun run eval:agent && bun run docs:check && bun run build && bun run lint:packages && bun scripts/smoke-packages.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@tsdown/css": "^0.22.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "gpt-tokenizer": "^3.4.0",
    "happy-dom": "^20.0.10",
    "publint": "^0.3.21",
    "tsdown": "^0.22.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
